# Base de datos local y caché HTTP (se regeneran con refresh.py)
db/listings.sqlite
db/listings.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm
cache/
__pycache__/
*.pyc

# Tus CSV personales (no se versionan; el ejemplo es sample_import.csv)
imports/*.csv

# Entornos virtuales
.venv/
venv/
web/img/

# graphify: internos con rutas absolutas del contenedor / caché.
# Los artefactos portables (graph.json, graph.html, GRAPH_REPORT.md, cost.json) SÍ se versionan.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_labels.json
graphify-out/manifest.json
